<!DOCTYPE html>                                                         <!-- Define que o documento usa HTML5 -->
<html lang="pt-br">                                                     <!-- Define o idioma da página -->
<head>
<meta charset="UTF-8">                                                  <!-- Permite usar acentos e caracteres especiais -->
<meta name="viewport" content="width=device-width, initial-scale=1.0">  <!-- Faz a página se adaptar a celulares e telas diferentes -->
<title>Minha Primeira Página</title>                                    <!-- Nome que aparece na aba do navegador -->
<style>
/* ============================= */
/* RESET DE ESTILO DO NAVEGADOR */
/* ============================= */
*{
margin:0;                       /* Remove margens automáticas dos elementos */
padding:0;                      /* Remove espaçamento interno automático */
box-sizing:border-box;          /* Faz o tamanho dos elementos considerar borda e padding dentro da largura */
}
/* ============================= */
/* ESTILO DO CORPO DA PÁGINA */
/* ============================= */
body{
font-family: Arial, sans-serif; /* Define a fonte usada no site */
background-color:#c9e1ff;     /* Cor de fundo da página */
display:flex;                   /* Ativa o sistema de layout flexbox */
flex-direction:column;          /* Organiza os elementos em coluna (de cima para baixo) */
align-items:center;             /* Centraliza os elementos horizontalmente */
}
/* ============================= */
    /* CABEÇALHO DA PÁGINA */
/* ============================= */
header{
width:100%;                     /* Faz o cabeçalho ocupar toda a largura da tela */
background-color:#2c3e50;     /* Cor de fundo do cabeçalho */
color:white;                  /* Cor do texto */
text-align:center;              /* Centraliza o texto */
padding:20px;                   /* Espaço interno entre borda e conteúdo */
}
/* ============================= */
  /* ÁREA PRINCIPAL DO SITE */
/* ============================= */
main{
background-color:white;                   /* Cor de fundo da área principal */
width:500px;                                /* Largura da caixa principal */
padding:30px;                               /* Espaçamento interno */
margin-top:30px;                            /* Espaço acima da caixa */
border-radius:15px;                         /* Arredonda as bordas */
box-shadow:0 5px 15px rgba(0,0,0,0.1);    /* Cria sombra ao redor da caixa */
}
/* ============================= */
      /* RODAPÉ DA PÁGINA */
/* ============================= */
footer{
margin-top:30px;                 /* Espaço entre o conteúdo e o rodapé */
background-color:#2c3e50;      /* Cor de fundo */
color:rgb(255, 255, 255);      /* Cor do texto */
width:100%;                      /* Ocupa toda a largura da tela */
text-align:center;               /* Centraliza o texto */
padding:15px;                    /* Espaçamento interno */
}
/* ============================= */
    /* CLASSE PERSONALIZADA */
/* ============================= */
.p1{
font-size:18px;                  /* Tamanho da fonte */
color:#2c3e50;                 /* Cor do texto */
margin-bottom:8px;               /* Espaço abaixo do parágrafo */
}
/* ============================= */
       /* ID PERSONALIZADO */
/* ============================= */
#p2{
font-size:28px;                  /* Fonte maior que a normal */
color:#2980b9;                 /* Cor azul */
margin-top:10px;                 /* Espaço acima do elemento */
}
/* ============================= */
         /* LISTAS */
/* ============================= */
ul,ol{
margin-top:10px;                 /* Espaço acima da lista */
margin-left:20px;                /* Espaço à esquerda para recuo da lista */
}
/* ============================= */
         /* LINKS */
/* ============================= */
a{
color:#2980b9;                 /* Cor do link */
text-decoration:none;            /* Remove o sublinhado padrão */
}
a:hover{
text-decoration:underline;       /* Quando passa o mouse no link ele fica sublinhado */
}
/* ============================= */
          /* IMAGEM */
/* ============================= */
img{
width:100%;                      /* Faz a imagem ocupar toda largura da caixa */
margin-top:15px;                 /* Espaço acima da imagem */
border-radius:10px;              /* Arredonda cantos da imagem */
}
</style>
</head>
<body>
<header>                              <!-- Cabeçalho do site -->
     <h1>Meu Primeiro Site</h1>       <!-- Título principal -->
     <p>Aprendendo HTML e CSS</p>     <!-- Subtítulo -->
</header>
<main>                                <!-- Conteúdo principal da página -->
    <h2>Exemplo de Títulos</h2>
    <h3>Título nível 3</h3>
    <h4>Título nível 4</h4>
    <p>Parágrafo normal</p>
    <p class="p1">Parágrafo usando classe</p>   <!-- class permite aplicar o mesmo estilo a vários elementos -->
    <p id="p2">Parágrafo usando ID</p>          <!-- id é único e usado para estilizar um elemento específico -->
    <h3>Lista não ordenada</h3>
    <ul>                              <!-- Lista com marcadores -->
        <li>HTML</li>                 <!-- Item da lista -->
        <li>CSS</li>
        <li>JavaScript</li>
    </ul>
    <h3>Lista ordenada</h3>
    <ol>                              <!-- Lista numerada -->
        <li>Aprender HTML</li>
        <li>Aprender CSS</li>
        <li>Criar um site</li>
    </ol>
    <p>
    Visite a <a href="https://www.wikipedia.org" target="_blank">Wikipedia</a>
    </p><!-- href = endereço do site -->  <!-- target="_blank" abre o link em nova aba -->
    <img src="https://th.bing.com/th/id/OIP.yW6YPOgMzUmwhJP_m-admwHaE7?w=275&h=183&c=7&r=0&o=7&pid=1.7&rm=3" alt="descrição da imagem">
    <!-- src = endereço da imagem -->  <!-- alt = descrição usada por leitores de tela ou se a imagem não carregar -->
</main>
<footer>                              <!-- Rodapé do site -->
    <p>Site criado para estudo de HTML e CSS</p>
</footer>
</body>
</html>
